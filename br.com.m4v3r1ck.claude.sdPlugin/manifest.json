      "Tooltip": "Approve Claude Code permission requests with a key press.",
      "Icon": "imgs/approve",
      "Controllers": ["Keypad"],
      "States": [ { "Image": "imgs/approve", "TitleAlignment": "bottom", "FontSize": "9" } ],
