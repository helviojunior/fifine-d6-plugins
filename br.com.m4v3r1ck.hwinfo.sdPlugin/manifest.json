      "Controllers": ["Keypad"],
      "States": [ { "Image": "imgs/graph", "TitleAlignment": "bottom", "FontSize": "9" } ],
      "SupportedInMultiActions": false
    },
    {
      "UUID": "br.com.m4v3r1ck.hwinfo.h.cpupwr",
