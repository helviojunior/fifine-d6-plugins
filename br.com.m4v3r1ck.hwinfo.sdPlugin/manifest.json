      "Name": "Fan (gauge)",
      "Tooltip": "System fan RPM as a radial gauge. Requires the sensor helper.",
      "Icon": "imgs/gauge",
      "Controllers": ["Keypad"],
      "States": [ { "Image": "imgs/gauge", "TitleAlignment": "bottom", "FontSize": "9" } ],
      "SupportedInMultiActions": false
